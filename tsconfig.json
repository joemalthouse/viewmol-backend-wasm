{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["pymol.ts", "render.ts", "test-api.ts", "test-new-api.ts", "test_label_debug.ts", "tests/*.ts"]
}
