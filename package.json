{
  "name": "viewmol",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/pymol-wasm",
    "packages/ray-tracer",
    "packages/app"
  ],
  "scripts": {
    "prepare-source": "npm -w @viewmol/pymol-wasm run prepare-source",
    "build:wasm": "npm -w @viewmol/pymol-wasm run build:wasm",
    "build:app": "npm -w @viewmol/app run build",
    "dev": "npm -w @viewmol/app run dev",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:smoke": "vitest run --project smoke",
    "test:parity": "tsx tests/parity/wasm-parity.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "playwright": "^1.50.0",
    "tsx": "^4.7.0",
    "typescript": "^5.5.0",
    "vitest": "^4.0.18"
  }
}
